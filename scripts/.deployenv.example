# Deploy + mock test credentials (keep this file local — gitignored)
# Copy this file to .deployenv, fill in your values, then run:
#   cargo run --bin xtask -- mock-deploy --report-dir=target/mock-report

# SSH connection
SSH_HOST=192.168.0.4
SSH_USER=dns2
SSH_PASSWORD=

# RustBlocker web UI admin password
WEBUI_PASSWORD=

# Web UI port (default: 54)
WEB_PORT=54

# Number of concurrent DB-heavy snapshot requests used by xtask mock-deploy to
# prove health/DNS responsiveness while SQLite work is active.
DB_CONCURRENCY_REQUESTS=16

# Number of concurrent /api/stats requests used by xtask mock-deploy to prove the
# stats endpoint remains responsive with retained query logs.
STATS_CONCURRENCY_REQUESTS=8

# Number of concurrent DNS hot-path queries used by xtask mock-deploy for exact
# blocklist, wildcard blocklist, and rewrite regression checks.
DNS_BURST_REQUESTS=96
DNS_BURST_MAX_MS=8000
DNS_BURST_MAX_FAILURES=0

# Domain used to prove parallel/adaptive upstream forwarding both resolve.
FORWARD_PROBE_DOMAIN=example.com

# Number of background DNS probes used while API hot-reload changes are applied.
HOT_RELOAD_DNS_REQUESTS=60

# Repeated import pressure used to catch source-refresh/import regressions.
MEMORY_IMPORT_LOOPS=3
MEMORY_IMPORT_DOMAINS=100

# Process resource guardrails for the deployed rustblocker process.
MEMORY_RSS_MAX_KB=262144
MEMORY_RSS_GROWTH_MAX_KB=131072
PROCESS_FD_MAX=1024
PROCESS_THREADS_MAX=128

# Query log prune storage guardrail. Larger targets can retain a small WAL briefly.
QUERY_LOG_PRUNE_WAL_MAX_BYTES=262144

# Optional blocklist capacity stress mode. This grows a temporary blocklist by
# tiers until DNS latency/resource thresholds reject a tier, writes the last
# accepted tier to STRESS_BASELINE_FILE, then cleans the prefix and restarts
# rustblocker. The default "auto" mode reads last_accepted_domains from
# STRESS_BASELINE_FILE and tests the next doubled value. Large tiers should use
# remote sqlite3 cleanup; without sqlite3, the script falls back to API cleanup
# only up to STRESS_API_CLEANUP_MAX_DOMAINS.
REMOTE_DB_PATH=/var/lib/rustblocker/rustblocker.db
MOCK_STRESS_BLOCKLIST=false
STRESS_INSTALL_SQLITE3=true
STRESS_BLOCKLIST_TIERS=auto
STRESS_AUTO_START_DOMAINS=10000
STRESS_AUTO_MULTIPLIER=2
STRESS_AUTO_PASSES=1
STRESS_AUTO_MAX_DOMAINS=0
# To override auto mode, provide an explicit ladder, for example:
# STRESS_BLOCKLIST_TIERS="10000 25000 50000 100000"
STRESS_BLOCKLIST_BATCH=1000
STRESS_DNS_SAMPLES=120
STRESS_DNS_P95_MAX_MS=250
STRESS_DNS_MAX_MS=1000
STRESS_DNS_MAX_FAILURES=0
STRESS_RSS_GROWTH_MAX_KB=131072
STRESS_BASELINE_MIN_DOMAINS=0
STRESS_BASELINE_FILE=target/mock-blocklist-stress-baseline.json
STRESS_API_CLEANUP_MAX_DOMAINS=10000
STRESS_API_CLEANUP_PAGE_SIZE=250

# Cloudflare + HTTPS / ACME integration checks are disabled by default.
# Set ENABLE_CLOUDFLARE_HTTPS=true only when the values below are configured
# and the Cloudflare token has the DNS permissions required for ACME.
ENABLE_CLOUDFLARE_HTTPS=false
DOMAIN=
ACME_EMAIL=
CF_TOKEN=
WILDCARD=false
